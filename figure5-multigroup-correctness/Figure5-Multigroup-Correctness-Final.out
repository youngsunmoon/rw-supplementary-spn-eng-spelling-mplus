INPUT INSTRUCTIONS

  TITLE:
    Figure 5: Final Multi-group Analysis with Correctness Scores

  DATA:
    FILE = Eng-SpnFinalData.dat;

  VARIABLE:
    NAMES =
      child_id sch_id d_female race d_hisp d_white d_asian d_g1farl d_g1el
      d_g1serv d_g1sspe d_g1sld d_g1saut d_g1soth d_g1dual d_g3farl d_g3el
      g3el_cat d_g3dual d_g3serv d_g3attr d_chdual g1engmis g1engsp g1engdl
      g1engdlr g1engcs g1engtd g3engmis g3engsp g3engdl g3engdlr g3engcs
      g3engtd g1spnmis g1spnsp g1spndl g1spndlr g1spncs g1spntd g3spnmis
      g3spnsp g3spndl g3spndlr g3spncs g3spntd zg1engsp zg1engdl zg1engcs
      zg1engtd zg3engsp zg3engdl zg3engcs zg3engtd zg1spnsp zg1spndl zg1spncs
      zg1spntd zg3spnsp zg3spndl zg3spncs zg3spntd gender ethnic s_g1farl
      s_g1serv s_g3serv;

    MISSING ARE ALL (9999);

  USEVARIABLES =
  zg1engsp zg3engsp zg1spnsp zg3spnsp d_g1el;

  GROUPING =
  d_g1dual (0 = English 1 = Dual);

  ANALYSIS:
  TYPE = MGROUP;
  Estimator = MLR;

  MODEL:
  !Model English Immersion
  zg3engsp ON zg1engsp ;
  zg3engsp ON zg1spnsp (b);
  zg3spnsp ON zg1engsp (c);
  zg3spnsp ON zg1spnsp (d);

  zg1engsp WITH zg1spnsp (e);
  zg3engsp WITH zg3spnsp (f);

  zg1engsp zg3engsp zg1spnsp zg3spnsp ON d_g1el;

  !Model Dual Immersion
  zg3engsp ON zg1engsp ;
  zg3engsp ON zg1spnsp (b);
  zg3spnsp ON zg1engsp (c);
  zg3spnsp ON zg1spnsp (d);

  zg1engsp WITH zg1spnsp (e);
  zg3engsp WITH zg3spnsp (f);

  zg1engsp zg3engsp zg1spnsp zg3spnsp ON d_g1el;

  OUTPUT:
  STDYX MODINDICES SAMPSTAT;



